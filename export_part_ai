        >
          <Sparkles size={22} color="#FFFFFF" />
        </TouchableOpacity>
      </Animated.View>

      <Modal visible={isOpen} animationType="slide" transparent>
        <View style={styles.modalOverlay}>
          <KeyboardAvoidingView
            behavior={Platform.OS === 'ios' ? 'padding' : 'height'}
