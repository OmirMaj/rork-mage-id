  { key: 'home', label: 'Projects', icon: Home, route: '/(tabs)/(home)', section: 'PROJECT' },
  { key: 'estimate', label: 'Estimate', icon: BarChart3, route: '/(tabs)/tools/estimate', section: 'PROJECT' },
  { key: 'schedule', label: 'Schedule', icon: CalendarDays, route: '/(tabs)/tools/schedule', section: 'PROJECT' },
