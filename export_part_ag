              <Text style={[styles.providerTagText, { color: providerInfo.color }]}>{providerInfo.label}</Text>
            </View>
            <Text style={styles.payCardDate}>
              {new Date(payment.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
