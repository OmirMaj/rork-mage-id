const SwipeableLookaheadCard = React.memo(function SwipeableLookaheadCard({
  task,
  allTasks,
  schedule,
  projectStartDate,
  onProgressUpdate,
  onTaskPress,
}: {
  task: ScheduleTask;
  allTasks: ScheduleTask[];
  schedule: ProjectSchedule;
