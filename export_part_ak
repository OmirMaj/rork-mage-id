              activeOpacity={0.7}
            >
              <View style={s.modelCardTop}>
                <View style={[s.modelIconWrap, { backgroundColor: Colors.primary + '12' }]}>
                  <CatIcon size={18} color={Colors.primary} />
                </View>
                <View style={s.modelCardInfo}>
                  <Text style={s.modelName}>{model.buildingType}</Text>
