                <Text style={s.modelRange}>${midRange.low}-${midRange.high}/SF</Text>
                <Text style={s.modelSize}>{model.typicalSizeRange.min.toLocaleString()}-{model.typicalSizeRange.max.toLocaleString()} SF</Text>
              </View>
            </TouchableOpacity>
          );
        })}
        <View style={{ height: 20 }} />
      </ScrollView>
