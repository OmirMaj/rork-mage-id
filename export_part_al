    bottom: 0,
    borderRadius: 8,
  },
  taskBarContent: {
    flexDirection: 'row',
    alignItems: 'center',
    gap: 4,
    paddingHorizontal: 8,
    paddingVertical: 6,
  },
  taskBarIcons: { flexDirection: 'row', gap: 2 },
  taskBarTitle: {
    flex: 1,
