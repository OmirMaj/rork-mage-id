          closed_at: project.closedAt, photo_count: project.photoCount,
          created_at: project.createdAt, updated_at: project.updatedAt,
        });
      }
      console.log('[ProjectContext] Synced project to Supabase:', project.name);
    }, 800));
  }, [canSync, userId]);

