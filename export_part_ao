export const PHASE_COLORS: Record<string, string> = {
  'Site Work': '#8B6914',
  'Demo': '#C75050',
  'Foundation': '#6B7280',
  'Framing': '#B45309',
  'Roofing': '#7C3AED',
  'MEP': '#0891B2',
  'Plumbing': '#2563EB',
  'Electrical': '#DC2626',
