        id: createId('con'),
        firstName: firstName.trim(),
        lastName: lastName.trim(),
        companyName: companyName.trim(),
        role,
        email: email.trim(),
        phone: phone.trim(),
        address: address.trim(),
        notes: notes.trim(),
        linkedProjectIds: [],
        createdAt: now,
        updatedAt: now,
