                  style={styles.supplierInput}
                  value={supAddress}
                  onChangeText={setSupAddress}
                  placeholder="123 Industrial Blvd, City, State"
                  placeholderTextColor={Colors.textMuted}
                />

                <Text style={styles.sectionSubtext}>Website</Text>
                <TextInput
