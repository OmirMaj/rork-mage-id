                  value={supWebsite}
                  onChangeText={setSupWebsite}
                  placeholder="yourcompany.com"
                  placeholderTextColor={Colors.textMuted}
                  autoCapitalize="none"
                />

                <Text style={styles.sectionSubtext}>Description</Text>
