          </View>
          <View style={styles.rowSeparator} />
          <View style={[styles.row, { opacity: 0.7 }]}>
            <View style={[styles.iconWrap, { backgroundColor: Colors.textMuted }]}>
              <ChevronRight size={14} color="#fff" />
            </View>
