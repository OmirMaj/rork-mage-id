}

const RADIUS_OPTIONS = [10, 25, 50, 100] as const;

const TRADE_FILTERS = [
  'Electrical', 'Plumbing', 'Carpentry', 'HVAC', 'Welding',
  'Masonry', 'Roofing', 'Management', 'Labor', 'General Construction',
] as const;

const TRADE_BADGE_COLORS: Record<string, string> = {
  'Electrical': '#F57F17',
  'Plumbing': '#1565C0',
  'Carpentry': '#6D4C41',
  'HVAC': '#00838F',
  'Welding': '#E65100',
