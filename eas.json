{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "credentialsSource": "remote",
      "env": {
        "EXPO_NO_CAPABILITY_SYNC": "1",
        "EAS_NO_FROZEN_LOCKFILE": "true",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      },
      "ios": {
        "credentialsSource": "remote",
        "autoIncrement": true
      }
    }
  },
  "submit": {
    "production": {}
  }
}
